{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "rootDir": "./src",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/sdk/**/*.ts",
    "src/runtime/**/*.ts",
    "src/config/**/*.ts",
    "src/vite/**/*.ts",
    "src/env.d.ts"
  ],
  "exclude": ["src/dev/**"]
}