{
  "name": "auto-exhibition-template-sdk",
  "version": "0.1.2",
  "description": "前端展览模板 SDK，提供 configJson 校验、valueMap 构建和 Vite 插件支持",
  "keywords": ["template", "sdk", "exhibition", "vue", "vite"],
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "config",
    "vite"
  ],
  "typesVersions": {
    "*": {
      "config": [
        "config/index.d.ts"
      ],
      "vite": [
        "vite/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./config": {
      "types": "./config/index.d.ts",
      "import": "./config/index.js",
      "default": "./config/index.js"
    },
    "./vite": {
      "types": "./vite/index.d.ts",
      "import": "./vite/index.js",
      "default": "./vite/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview"
  },
  "sideEffects": false,
  "peerDependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  }
}
